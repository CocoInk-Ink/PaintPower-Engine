<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PaintPower.VMPanel.LoadingBar">

    <Grid x:Name="Root" Width="210" Height="22" ClipToBounds="True">

        <!-- Background -->
        <Border Background="#d0d0d0"
                CornerRadius="6"/>

        <!-- Fill -->
        <Border x:Name="FillBar"
                Background="#179fd7"
                CornerRadius="6"
                Width="0"
                HorizontalAlignment="Left"/>
    </Grid>
</UserControl>
