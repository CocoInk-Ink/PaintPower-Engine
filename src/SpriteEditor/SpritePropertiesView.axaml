<UserControl xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="PaintPower.SpriteEditor.SpritePropertiesView">
    <Border Background="#252525" Padding="10">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="10">
                <TextBlock Text="Sprite Properties" Foreground="White" Margin="8" />
                <Separator />
                <!-- Sprite Name -->
                <TextBlock Text="Sprite Name" Foreground="White" FontSize="14" />
                <TextBox x:Name="NameBox" Background="#404040" Foreground="White" BorderBrush="#606060" />
                <Separator />
                <!-- Skins List -->
                <TextBlock Text="Skins" Foreground="White" FontSize="14" />
                <ListBox x:Name="SkinsList" Background="#202020" Foreground="White" BorderBrush="#404040" BorderThickness="1" Height="150" />
                <!-- Skin Buttons -->
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Button x:Name="AddSkinButton" Content="Add" Classes="white" />
                    <Button x:Name="RemoveSkinButton" Content="Remove" Classes="white" />
                    <Button x:Name="RenameSkinButton" Content="Rename" Classes="white" />
                </StackPanel>
                <Separator />
                <!-- Thumbnail Preview -->
                <TextBlock Text="Thumbnail" Foreground="White" FontSize="14" />
                <Border Background="#101010" BorderBrush="#404040" BorderThickness="1" Padding="4">
                    <Image x:Name="ThumbnailImage" Stretch="Uniform" />
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>