<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="PaintPower.Dialogs.PopupWindowDialog"
        Width="300" Height="150"
        WindowStartupLocation="CenterOwner">

    <StackPanel Margin="10" Spacing="10">
		<TextBlock FontSize="20" x:Name="HeaderText" />
		<TextBlock FontSize="15" x:Name="PromptText"/>
		
		<Button x:Name="OkButton" Classes="white" Content="Ok" Click="OnOk"/>
    </StackPanel>
</Window>