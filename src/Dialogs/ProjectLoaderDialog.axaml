<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="PaintPower.Dialogs.ProjectLoaderDialog"
        Width="350" Height="200"
        WindowStartupLocation="CenterScreen"
        Title="PaintPower Project">

    <StackPanel Margin="20" Spacing="15">

        <TextBlock x:Name="WelcomeText" Text="Welcome to the PaintPower engine!"
                   FontSize="18"
                   HorizontalAlignment="Center"/>

		<Button x:Name="NewProjectButton" Classes="white" Content="Create New Project"
                Click="OnNewProject"/>

		<Button x:Name="OpenProjectButton" Classes="gray" Content="Open Existing Project"
                Click="OnOpenProject"/>

    </StackPanel>
</Window>