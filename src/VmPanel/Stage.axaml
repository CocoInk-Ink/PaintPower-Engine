             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PaintPower.VMPanel.Stage">
    <StackPanel>
        <Border Width="640" Height="450" BorderBrush="gray" Background="white" BorderThickness="1" CornerRadius="0,0,8,8" Padding="10" />
    </StackPanel>
</UserControl>